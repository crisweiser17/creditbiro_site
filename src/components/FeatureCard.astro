---
import { CheckCircle, Search, FileText, AlertTriangle, Globe, MapPin, Gavel } from 'lucide-react';

interface Props {
  title: string;
  description: string;
  icon: string;
}

const { title, description, icon } = Astro.props;

// Map string icon names to components
const IconMap = {
  'search': Search,
  'file-text': FileText,
  'alert-triangle': AlertTriangle,
  'globe': Globe,
  'map-pin': MapPin,
  'gavel': Gavel,
  'check-circle': CheckCircle
};

const IconComponent = IconMap[icon] || CheckCircle;
---

<div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm hover:shadow-md transition-shadow">
  <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center text-blue-600 mb-4">
    <IconComponent className="w-6 h-6" />
  </div>
  <h3 class="text-lg font-bold text-slate-900 mb-2">{title}</h3>
  <p class="text-slate-600 text-sm leading-relaxed">
    {description}
  </p>
</div>

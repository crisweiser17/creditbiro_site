---
interface Props {
  title: string;
  price: string;
  credits: string;
  features?: string[];
  highlighted?: boolean;
  buttonText?: string;
  link?: string;
}

const { title, price, credits, features = [], highlighted = false, buttonText = "Começar Agora", link = "/contato" } = Astro.props;
---

<div class={`rounded-2xl p-8 flex flex-col h-full border ${highlighted ? 'border-blue-500 bg-white shadow-xl ring-2 ring-blue-500/20' : 'border-slate-200 bg-white shadow-sm hover:shadow-md transition-shadow'}`}>
  {highlighted && (
    <div class="text-xs font-bold text-blue-600 uppercase tracking-wide mb-2">Recomendado</div>
  )}
  <h3 class="text-xl font-bold text-slate-900 mb-2">{title}</h3>
  <div class="mb-6">
    <span class="text-4xl font-bold text-slate-900">{price}</span>
    {price !== 'Grátis' && <span class="text-slate-500 text-sm">/mês</span>}
  </div>
  
  <div class="mb-6">
    <p class="font-semibold text-slate-700 mb-1">Créditos inclusos:</p>
    <p class="text-2xl font-bold text-blue-600">{credits}</p>
  </div>

  <ul class="space-y-3 mb-8 flex-1">
    {features.map(feature => (
      <li class="flex items-start gap-2 text-sm text-slate-600">
        <svg class="w-5 h-5 text-green-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
        {feature}
      </li>
    ))}
  </ul>

  <a 
    href={link} 
    class={`block w-full text-center py-3 px-4 rounded-lg font-bold transition-colors ${highlighted ? 'bg-blue-600 text-white hover:bg-blue-700' : 'bg-slate-100 text-slate-900 hover:bg-slate-200'}`}
  >
    {buttonText}
  </a>
</div>
